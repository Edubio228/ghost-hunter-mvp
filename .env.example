# ============================================================
# GHOST HUNTER - ENVIRONMENT VARIABLES (EXAMPLE)
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your actual .env file to GitHub!
# ============================================================

# ---------- SECURITY ----------
# REQUIRED: Generate a secure random key
# Run: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secure-random-key-here-change-this-in-production

# ---------- GITHUB API ----------
# REQUIRED: GitHub Personal Access Token (classic) with repo scope
# Generate at: https://github.com/settings/tokens
# Scopes needed: repo (or public_repo) + admin:org (for auto-recover)
GITHUB_TOKEN=ghp_your_actual_github_token_here

# REQUIRED: Your GitHub organization name
# Example: if your org URL is https://github.com/acme-corp, use acme-corp
GITHUB_ORG=your-github-org-name

# ---------- SLACK API ----------
# REQUIRED: Slack Bot User OAuth Token (starts with xoxb-)
# Get from: https://api.slack.com/apps -> Your App -> OAuth & Permissions
SLACK_BOT_TOKEN=xoxb_your_actual_slack_token_here

# REQUIRED: Slack channel ID for notifications
# Right-click a channel -> Copy Link -> Extract the ID (starts with C)
# Example: https://your-workspace.slack.com/archives/C1234567890 -> C1234567890
SLACK_NOTIFICATION_CHANNEL=CXXXXXXXXXX

# ---------- OPENROUTER AI ----------
# REQUIRED: OpenRouter API key for AI roast generation
# Get from: https://openrouter.ai/keys
# Free tier available!
OPENROUTER_API_KEY=sk-or-v1_your_actual_openrouter_key_here

# ---------- DATABASE ----------
# Optional: Defaults to SQLite if not set
# For development: sqlite:///./ghost_hunter.db
# For production: postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///./ghost_hunter.db

# ---------- APP SETTINGS ----------
# TEST_MODE: True = simulate recover actions (safe)
#            False = actually remove users from GitHub
# Recommended: True for testing, False when you're ready for real action
TEST_MODE=True

# ---------- ADMIN ACCOUNT (First Run) ----------
# These are only used on the FIRST run to create the admin account
# After the account is created, you can remove these or change the password
ADMIN_EMAIL=admin@demo.com
ADMIN_PASSWORD=admin123

# ---------- OPTIONAL: Cloud Deployment ----------
# Only needed if deploying to Render/Railway
# PORT=10000
# HOST=0.0.0.0